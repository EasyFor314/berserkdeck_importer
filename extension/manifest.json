{
  "manifest_version": 3,
  "name": "Berserk Deck Importer",
  "version": "1.2.0",
  "description": "Показывает текстовый вид колоды или альбома с berserkdeck.ru и копирует в буфер обмена",
  "permissions": ["activeTab", "clipboardWrite", "scripting"],
  "host_permissions": [
    "https://www.berserkdeck.ru/*",
    "https://berserkdeck.ru/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Berserk Deck Importer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
